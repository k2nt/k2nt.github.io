---
import "../styles/global.css";

import BaseHead from "../components/BaseHead.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** Use the wider container for listing/landing pages. */
  wide?: boolean;
  /** Render the slot full-bleed (no main/container) for custom layouts. */
  full?: boolean;
}

const { title, description, image, wide = false, full = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body>
    {
      full ? (
        <slot />
      ) : (
        <main>
          <div class:list={["container", { "container--wide": wide }]}>
            <slot />
          </div>
        </main>
      )
    }
  </body>
</html>

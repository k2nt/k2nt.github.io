---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, ABOUT, SOCIAL } from "../config";

const tabs = [
  { label: "Blog", href: "/blog" },
  { label: "TIL", href: "/til" },
];

const links = SOCIAL.filter((item) => item.href.length > 0);
---

<BaseLayout full>
  <div class="landing">
    <section class="landing__intro">
      <h1 class="landing__name">{SITE.title}</h1>
      <p class="landing__tagline">{SITE.tagline}</p>
      {ABOUT.map((paragraph) => <p class="landing__about">{paragraph}</p>)}
    </section>

    <nav class="landing__nav" aria-label="Sections">
      <ul class="landing__tabs">
        {
          tabs.map((tab) => (
            <li>
              <a href={tab.href}>{tab.label}</a>
            </li>
          ))
        }
      </ul>

      {
        links.length > 0 && (
          <ul class="landing__links">
            {links.map((link) => {
              const isMailto = link.href.startsWith("mailto:");
              return (
                <li>
                  <a
                    href={link.href}
                    rel="me noopener"
                    target={isMailto ? undefined : "_blank"}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        )
      }
    </nav>
  </div>
</BaseLayout>

<style>
  .landing {
    min-height: 100vh;
    max-width: var(--wide-width);
    margin-inline: auto;
    padding: var(--space-6) var(--space-4);
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }

  .landing__name {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-2);
  }

  .landing__tagline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .landing__about {
    margin: 0 0 var(--space-3);
  }

  .landing__about:last-of-type {
    margin-bottom: 0;
  }

  /* The vertical split: a divider between intro and tabs. */
  .landing__nav {
    border-left: 1px solid var(--color-border);
    padding-left: var(--space-5);
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-5);
  }

  .landing__tabs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .landing__tabs a {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .landing__tabs a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .landing__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  .landing__links a {
    color: var(--color-text-muted);
  }

  .landing__links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 48rem) {
    .landing {
      grid-template-columns: 1fr;
      gap: var(--space-5);
      align-items: start;
      min-height: 0;
      padding-block: var(--space-5);
    }

    .landing__nav {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
      padding-top: var(--space-5);
      justify-content: flex-start;
    }
  }
</style>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, ABOUT } from "../config";

const tabs = [
  { label: "Blog", href: "/blog" },
  { label: "TIL", href: "/til" },
  { label: "Photos", href: "/photos" },
];
---

<BaseLayout full>
  <div class="landing">
    <section class="landing__intro">
      <h1 class="landing__name">{SITE.author}</h1>
      {ABOUT.map((paragraph) => <p class="landing__about">{paragraph}</p>)}
    </section>

    <nav class="landing__nav" aria-label="Sections">
      <ul class="landing__tabs">
        {
          tabs.map((tab) => (
            <li>
              <a href={tab.href}>{tab.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</BaseLayout>

<style>
  .landing {
    flex: 1 0 auto;
    width: 100%;
    max-width: var(--wide-width);
    margin-inline: auto;
    padding: var(--space-6) var(--space-4);
    display: grid;
    grid-template-columns: 1.618fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }

  .landing__name {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-5);
  }

  .landing__about {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .landing__about:last-of-type {
    margin-bottom: 0;
  }

  /* The vertical split: no divider between intro and tabs. */
  .landing__nav {
    border-left: none;
    padding-left: var(--space-5);
    align-self: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .landing__tabs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .landing__tabs a {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    letter-spacing: -0.01em;
  }

  .landing__tabs a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 48rem) {
    .landing {
      grid-template-columns: 1fr;
      gap: var(--space-5);
      align-items: start;
      padding-block: var(--space-5);
    }

    .landing__nav {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
      padding-top: var(--space-5);
      justify-content: flex-start;
    }
  }
</style>
